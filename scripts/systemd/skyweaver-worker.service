[Unit]
Description=Sky Weaver Hub processing worker
After=skyweaver-api.service
PartOf=skyweaver.target

[Service]
Type=simple
User=skyweaver
Group=skyweaver
SupplementaryGroups=video render input gpio i2c spi
WorkingDirectory=/opt/skyweaver
EnvironmentFile=-/etc/skyweaver/skyweaver.env
Environment=PYTHONPATH=/opt/skyweaver/backend
ExecStart=/opt/skyweaver/backend/.venv/bin/python -m skyweaver.worker
Restart=on-failure
RestartSec=5

[Install]
WantedBy=skyweaver.target
